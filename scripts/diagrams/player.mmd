flowchart TD
    A[_physics_process] --> B[_get_input_direction]
    A --> C[_update_facing]
    A --> D[_handle_attack]
    A --> E[_handle_movement]
    A --> F[_update_animation]
    
    subgraph Input & State
        B
        C
        D
    end
    
    subgraph Movement
        E
    end
    
    subgraph Visuals
        F
    end
    
    F --> G{is_attacking?}
    G -->|Yes| H[Attack Animation]
    G -->|No| I{is_on_floor?}
    I -->|No| J[Jump Animation]
    I -->|Yes| K{Direction == 0?}
    K -->|Yes| L[Idle Animation]
    K -->|No| M[Run Animation]
    
    D -->|Attack pressed| N[is_attacking = true]
    F -.->|Animation finished| O[_on_animation_finished]
    O --> P[is_attacking = false]
    
    style A fill:#4ade80,stroke:#166534